# Video Learner 配置文件示例
# 复制此文件为 .env 并填写实际值

# ===== 必需配置 =====

# GLM API Key (用于笔记生成)
# 获取地址: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key

# 阿里云 DashScope ASR API Key (用于语音转录)
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key
ALIYUN_ASR_API_KEY=your_dashscope_api_key

# 飞书应用配置 (上传笔记)
# 获取地址: https://open.feishu.cn/app
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# ===== 可选配置 =====

# 代理配置 (中国大陆网络环境可能需要)
# 海外服务器请留空或删除此配置
# 格式: http://127.0.0.1:7897 或 socks5://127.0.0.1:1080
# VIDEO_LEARNER_PROXY=http://127.0.0.1:7897

# 工作目录 (默认值)
WORKSPACE=~/.openclaw/workspace-video-learner

# B站cookies文件路径 (默认: cookies/bilibili_cookies.txt)
# 获取方式: 浏览器登录bilibili.com后，使用EditThisCookie扩展导出
# BILIBILI_COOKIES=~/.openclaw/workspace-video-learner/cookies/bilibili_cookies.txt
